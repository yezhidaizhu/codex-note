{
  appId: 'com.coco.note',
  productName: 'Coco Note',
  directories: {
    output: 'release/${version}'
  },
  files: ['dist/**/*', 'dist-electron/**/*', 'resources/icon.png', 'package.json'],
  mac: {
    icon: 'resources/icon.icns',
    target: ['dmg']
  },
  win: {
    target: ['nsis']
  },
  linux: {
    icon: 'resources/icon.png',
    target: ['AppImage']
  }
}
